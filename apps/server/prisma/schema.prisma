generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Admin {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}



model Product {
  id          String         @id @default(uuid())
  sku         String         @default("")
  name        String
  slug        String         @unique
  description String
  price       Int
  glassType   String
  stock       Int
  thumbnail   String
  isFeatured  Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  images      ProductImage[]
  models      ProductModel[]
}

model ProductImage {
  id        String  @id @default(uuid())
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  imageUrl  String
  sortOrder Int     @default(0)
}

model ProductModel {
  id         String  @id @default(uuid())
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId  String
  modelName  String
}
